{
  "name": "avatar-chat-backend",
  "version": "1.0.0",
  "description": "Backend for a real-time voice-based chatbot system using Fastify, STT, TTS and LLM APIs.",
  "main": "app.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "imports": {
    "#@/*": "./dist/*.js"
  },
  "scripts": {
    "start": "pnpm build && fastify start -l info dist/app.js",
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "watch": "tsc -w",
    "dev": "pnpm build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:dev:start\"",
    "dev:start": "pnpm build && fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "test": "pnpm db:seed && c8 pnpm test:run",
    "test:run": "glob -c \"tsx --test\" \"./test/**/*.ts\"",
    "standalone": "pnpm build && node --env-file=.env dist/server.js",
    "lint": "eslint --ignore-pattern=dist",
    "lint:fix": "pnpm lint -- --fix",
    "db:create": "tsx --env-file=.env ./scripts/create-database.ts",
    "db:drop": "tsx --env-file=.env ./scripts/drop-database.ts",
    "db:migrate": "tsx --env-file=.env ./scripts/migrate.ts",
    "db:seed": "tsx --env-file=.env ./scripts/seed-database.ts"
  },
  "keywords": [],
  "author": "Rheefine <rheefine@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.9.0",
  "dependencies": {
    "@fastify/autoload": "^6.3.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@sinclair/typebox": "^0.34.33",
    "close-with-grace": "^2.2.0",
    "concurrently": "^9.1.2",
    "fastify": "^5.3.2",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "7.6.0",
    "@typescript-eslint/parser": "7.6.0",
    "c8": "^10.1.3",
    "eslint": "8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "fastify-tsconfig": "^3.0.0",
    "glob": "^11.0.1",
    "prettier": "3.5.3",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3"
  }
}
